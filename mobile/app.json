{
  "expo": {
    "name": "KARVENTER",
    "slug": "karventer-mobile",
    "version": "1.0.19",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "karventer",
    "splash": {
      "backgroundColor": "#2563EB",
      "resizeMode": "contain",
      "image": "./assets/icon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karventer.mobile"
    },
    "android": {
      "package": "com.karventer.mobile",
      "versionCode": 7,
      "adaptiveIcon": {
        "backgroundColor": "#2563EB",
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "apiUrl": "https://sep-examines-cms-layout.trycloudflare.com",
      "eas": {
        "projectId": "86b19077-b94b-4f04-be07-386c5fdf27ce"
      }
    },
    "plugins": [
      "./plugins/withAndroidCleartext",
      [
        "expo-camera",
        {
          "cameraPermission": "KARVENTER barkod tarama için kameraya erişir."
        }
      ]
    ],
    "icon": "./assets/icon.png"
  }
}
